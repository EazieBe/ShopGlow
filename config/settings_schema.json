{
  "name": "GlowingInCoach Theme",
  "theme_author": "GlowingInCoach",
  "theme_version": "1.0.0",
  "theme_documentation_url": "https://github.com/EazieBe/ShopGlow",
  "settings": [
    {
      "name": "Brand",
      "settings": [
        {
          "type": "image_picker",
          "id": "favicon",
          "label": "Favicon"
        },
        {
          "type": "color",
          "id": "color_primary",
          "label": "Primary Color (Hot Pink)",
          "default": "#E91E8C"
        },
        {
          "type": "color",
          "id": "color_secondary",
          "label": "Secondary Color (Purple)",
          "default": "#7B1FA2"
        },
        {
          "type": "color",
          "id": "color_accent",
          "label": "Accent Color (Gold)",
          "default": "#FFD700"
        },
        {
          "type": "color",
          "id": "color_background",
          "label": "Page Background",
          "default": "#FFF8FC"
        },
        {
          "type": "color",
          "id": "color_text",
          "label": "Body Text Color",
          "default": "#2D1B35"
        }
      ]
    },
    {
      "name": "Typography",
      "settings": [
        {
          "type": "select",
          "id": "heading_font",
          "label": "Heading Font",
          "options": [
            {
              "value": "'Cormorant Garamond', serif",
              "label": "Cormorant Garamond (Recommended)"
            },
            {
              "value": "'Playfair Display', serif",
              "label": "Playfair Display"
            },
            {
              "value": "'Georgia', serif",
              "label": "Georgia"
            }
          ],
          "default": "'Cormorant Garamond', serif"
        },
        {
          "type": "select",
          "id": "body_font",
          "label": "Body Font",
          "options": [
            {
              "value": "'Nunito', sans-serif",
              "label": "Nunito (Recommended)"
            },
            {
              "value": "'Georgia', serif",
              "label": "Georgia"
            }
          ],
          "default": "'Nunito', sans-serif"
        }
      ]
    },
    {
      "name": "Social Media",
      "settings": [
        {
          "type": "text",
          "id": "instagram_url",
          "label": "Instagram URL"
        },
        {
          "type": "text",
          "id": "tiktok_url",
          "label": "TikTok URL"
        },
        {
          "type": "text",
          "id": "poshmark_url",
          "label": "Poshmark URL",
          "default": "https://poshmark.com/closet/glowingincoach"
        },
        {
          "type": "text",
          "id": "pinterest_url",
          "label": "Pinterest URL"
        }
      ]
    }
  ]
}