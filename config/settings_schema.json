[
  {
    "name": "Logo & Favicon",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo",
        "info": "Upload your GlowingInCoach transparent PNG logo. Appears in the nav bar and loading screen."
      },
      {
        "type": "range",
        "id": "logo_width",
        "label": "Logo width",
        "min": 60,
        "max": 250,
        "step": 10,
        "default": 160,
        "unit": "px"
      },
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon",
        "info": "Small icon shown in browser tab. Use a square version of your logo."
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_primary",
        "label": "Primary Gold",
        "default": "#C9A84C"
      },
      {
        "type": "color",
        "id": "color_secondary",
        "label": "Gold Light",
        "default": "#F0D080"
      },
      {
        "type": "color",
        "id": "color_background",
        "label": "Page Background",
        "default": "#FFF9F5"
      },
      {
        "type": "color",
        "id": "color_text",
        "label": "Body Text",
        "default": "#2A1A0E"
      },
      {
        "type": "color",
        "id": "color_dark_bg",
        "label": "Dark Section Background",
        "default": "#1C100A"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "select",
        "id": "heading_font",
        "label": "Heading Font",
        "options": [
          {
            "value": "'Cormorant Garamond', serif",
            "label": "Cormorant Garamond (Recommended)"
          },
          {
            "value": "'Playfair Display', serif",
            "label": "Playfair Display"
          },
          {
            "value": "'Georgia', serif",
            "label": "Georgia"
          }
        ],
        "default": "'Cormorant Garamond', serif"
      },
      {
        "type": "select",
        "id": "body_font",
        "label": "Body Font",
        "options": [
          {
            "value": "'Nunito', sans-serif",
            "label": "Nunito (Recommended)"
          },
          {
            "value": "'Lato', sans-serif",
            "label": "Lato"
          },
          {
            "value": "system-ui, sans-serif",
            "label": "System Default"
          }
        ],
        "default": "'Nunito', sans-serif"
      }
    ]
  },
  {
    "name": "Social Media",
    "settings": [
      {
        "type": "url",
        "id": "instagram_url",
        "label": "Instagram URL"
      },
      {
        "type": "url",
        "id": "tiktok_url",
        "label": "TikTok URL"
      },
      {
        "type": "url",
        "id": "poshmark_url",
        "label": "Poshmark URL"
      },
      {
        "type": "url",
        "id": "pinterest_url",
        "label": "Pinterest URL"
      }
    ]
  },
  {
    "name": "Shipping",
    "settings": [
      {
        "type": "number",
        "id": "free_shipping_threshold",
        "label": "Free shipping threshold ($)",
        "default": 75,
        "info": "Orders above this amount get free shipping"
      }
