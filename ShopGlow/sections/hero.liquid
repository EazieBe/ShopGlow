<section class="gic-hero" id="gic-hero">
  <div class="hero-ambient"></div>

  <div class="hero-left">
    <div class="hero-eyebrow">
      <span class="hero-eyebrow-dot"></span>
      {{ section.settings.badge_text }}
    </div>

    <h1 class="hero-title">
      {{ section.settings.heading_line1 }}<br>
      {{ section.settings.heading_line2 }}<br>
      {{ section.settings.heading_line3 }}<br>
      <span class="hero-title-glow">{{ section.settings.heading_glow }}</span>
    </h1>

    <p class="hero-sub">{{ section.settings.subtext }}</p>

    <div class="hero-ctas">
      <a href="{{ section.settings.btn1_url }}" class="btn-gold">
        {{ section.settings.btn1_text }}
      </a>
      {%- if section.settings.btn2_url != blank -%}
        <a href="{{ section.settings.btn2_url }}" class="btn-ghost" target="_blank">
          {{ section.settings.btn2_text }}
        </a>
      {%- endif -%}
    </div>

    <div class="hero-proof">
      {%- for block in section.blocks -%}
        {%- if block.type == 'stat' -%}
          <div class="proof-stat" {{ block.shopify_attributes }}>
            <div class="proof-num">{{ block.settings.number }}</div>
            <div class="proof-label">{{ block.settings.label }}</div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  <div class="hero-right">
    <div class="portrait-wrap">
      <div class="portrait-halo"></div>
      {%- if section.settings.portrait_image != blank -%}
        <img
          src="{{ section.settings.portrait_image | image_url: width: 900 }}"
          alt="{{ shop.name }}"
          class="portrait-img"
          width="460"
          loading="eager">
      {%- else -%}
        <div class="portrait-img" style="font-size:10rem;display:flex;align-items:center;justify-content:center;">👜</div>
      {%- endif -%}

      <div class="proof-chip c1">
        <div class="chip-ico">✅</div>
        <div>
          <div class="chip-label">Authenticated</div>
          <div class="chip-val">Vintage Coach</div>
        </div>
      </div>
      <div class="proof-chip c2">
        <div class="chip-ico">🚚</div>
        <div>
          <div class="chip-label">Free Shipping</div>
          <div class="chip-val">Orders $75+</div>
        </div>
      </div>
      <div class="proof-chip c3">
        <div class="chip-ico">⭐</div>
        <div>
          <div class="chip-label">Posh Ambassador</div>
          <div class="chip-val">Top Seller</div>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "text", "id": "badge_text", "label": "Badge text", "default": "✨ Posh Ambassador · 16.5K Followers" },
    { "type": "text", "id": "heading_line1", "label": "Heading line 1", "default": "Vintage Coach &" },
    { "type": "text", "id": "heading_line2", "label": "Heading line 2", "default": "Fashion Finds" },
    { "type": "text", "id": "heading_line3", "label": "Heading line 3", "default": "that make you" },
    { "type": "text", "id": "heading_glow", "label": "Glowing word", "default": "Glow." },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Curated vintage Coach bags, designer handbags & fashion finds — handpicked with love by Glo. Authenticated. Affordable. Iconic." },
    { "type": "text", "id": "btn1_text", "label": "Button 1 text", "default": "Shop Direct 🛍" },
    { "type": "url", "id": "btn1_url", "label": "Button 1 URL" },
    { "type": "text", "id": "btn2_text", "label": "Button 2 text", "default": "Browse Poshmark" },
    { "type": "url", "id": "btn2_url", "label": "Button 2 URL" },
    {
      "type": "image_picker",
      "id": "portrait_image",
      "label": "Hero portrait image",
      "info": "Upload your portrait logo or a photo of you. Displays on the right side of the hero."
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        { "type": "text", "id": "number", "label": "Number", "default": "246+" },
        { "type": "text", "id": "label", "label": "Label", "default": "Listings" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero",
      "blocks": [
        { "type": "stat", "settings": { "number": "246+", "label": "Listings" } },
        { "type": "stat", "settings": { "number": "16.5K", "label": "Followers" } },
        { "type": "stat", "settings": { "number": "17.8K", "label": "Shares" } },
        { "type": "stat", "settings": { "number": "5★", "label": "Rated" } }
      ]
    }
  ]
}
{% endschema %}
