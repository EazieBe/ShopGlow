{%- if section.settings.announcement_text != blank -%}
<div class="gic-announcement" id="gic-ann" role="banner">
  <span>{{ section.settings.announcement_text }}</span>
  <button class="announcement-close" aria-label="Close announcement" onclick="
    var a=document.getElementById('gic-ann');
    a.style.cssText='height:0;padding:0;overflow:hidden;opacity:0;transition:all .3s ease;';
    sessionStorage.setItem('gic-ann-closed','1');
  ">✕</button>
</div>
<script>
  if(sessionStorage.getItem('gic-ann-closed')){
    document.getElementById('gic-ann').style.display='none';
  }
</script>
{%- endif -%}

<nav class="gic-nav" id="gic-nav" role="navigation" aria-label="Main navigation">
  <div class="nav-inner">

    <!-- LOGO -->
    <a href="{{ routes.root_url }}" class="nav-logo" aria-label="{{ shop.name }}">
      {%- if section.settings.logo != blank -%}
        <img
          src="{{ section.settings.logo | image_url: width: 320 }}"
          alt="{{ shop.name }}"
          loading="eager"
          fetchpriority="high"
          style="height:{{ section.settings.logo_height }}px;width:auto;max-width:220px;object-fit:contain;">
      {%- else -%}
        <span style="font-family:'Cormorant Garamond',serif;font-size:1.4rem;font-weight:600;
          background:linear-gradient(135deg,#C9A84C,#F0D080);
          -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">
          {{ shop.name }}
        </span>
      {%- endif -%}
    </a>

    <!-- DESKTOP LINKS -->
    <ul class="nav-links" role="list">
      {%- for link in section.settings.menu.links -%}
        <li>
          <a href="{{ link.url }}"
             class="nav-link{% if link.active %} active{% endif %}{% if link.title contains 'Sale' or link.title contains 'sale' %} sale{% endif %}"
             {% if link.active %}aria-current="page"{% endif %}>
            {{ link.title }}
          </a>
        </li>
      {%- endfor -%}
    </ul>

    <!-- ACTIONS -->
    <div class="nav-actions">
      <!-- Search -->
      <button class="nav-icon-btn" aria-label="Search" onclick="
        var o=document.createElement('div');
        o.style.cssText='position:fixed;inset:0;background:rgba(28,16,10,.9);backdrop-filter:blur(22px);z-index:9000;display:flex;align-items:flex-start;justify-content:center;padding-top:15vh;';
        o.innerHTML='<div style=\'width:100%;max-width:580px;padding:0 24px\'><form action=\'{{ routes.search_url }}\' method=\'get\'><input name=\'q\' type=\'text\' placeholder=\'Search bags, brands...\' autofocus style=\'width:100%;padding:18px 26px;border:none;border-radius:9999px;font-size:1.05rem;font-family:Nunito,sans-serif;background:rgba(255,249,245,.97);color:#2A1A0E;outline:none;box-shadow:0 8px 36px rgba(201,168,76,.22);\'></form></div>';
        document.body.appendChild(o);
        o.addEventListener('click',function(e){if(e.target===o)o.remove();});
        document.addEventListener('keydown',function h(e){if(e.key==='Escape'){o.remove();document.removeEventListener('keydown',h);}});
        setTimeout(function(){o.querySelector('input').focus();},100);
      ">
        <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
      </button>

      <!-- Wishlist -->
      <button class="nav-icon-btn" aria-label="Wishlist">
        <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
      </button>

      <!-- Cart -->
      <a href="{{ routes.cart_url }}" class="nav-icon-btn" aria-label="Cart ({{ cart.item_count }} items)" style="position:relative;">
        <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
        <span class="cart-count" style="display:{% if cart.item_count > 0 %}flex{% else %}none{% endif %}">{{ cart.item_count }}</span>
      </a>

      <!-- CTA Button -->
      <a href="{{ routes.collections_url }}" class="nav-shop-btn">Shop Now ✨</a>

      <!-- Mobile toggle -->
      <button class="mobile-menu-btn" id="mobile-toggle" aria-label="Open menu" aria-expanded="false">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
    </div>

  </div>

  <!-- MOBILE NAV -->
  <div class="mobile-nav" id="mobile-nav" aria-hidden="true">
    {%- for link in section.settings.menu.links -%}
      <a href="{{ link.url }}" class="mobile-nav-link">{{ link.title }}</a>
    {%- endfor -%}
    <div style="height:1px;background:rgba(201,168,76,.15);margin:8px 0;"></div>
    <a href="{{ routes.search_url }}" class="mobile-nav-link">🔍 Search</a>
    <a href="{{ routes.cart_url }}" class="mobile-nav-link">🛍 Cart
      {%- if cart.item_count > 0 -%}
        &nbsp;<span style="background:linear-gradient(135deg,#C9A84C,#F0D080);color:#2A1A0E;padding:2px 9px;border-radius:50px;font-size:.72rem;font-weight:800;">{{ cart.item_count }}</span>
      {%- endif -%}
    </a>
  </div>
</nav>

<script>
(function(){
  // Mobile menu
  var btn=document.getElementById('mobile-toggle'),nav=document.getElementById('mobile-nav');
  if(btn&&nav){
    btn.addEventListener('click',function(){
      var open=nav.classList.toggle('open');
      btn.setAttribute('aria-expanded',open);
      nav.setAttribute('aria-hidden',!open);
    });
  }
  // Scroll effect
  var gicNav=document.getElementById('gic-nav');
  if(gicNav){
    window.addEventListener('scroll',function(){
      gicNav.classList[window.scrollY>60?'add':'remove']('scrolled');
    },{passive:true});
  }
})();
</script>

{% schema %}
{
  "name": "Header",
  "class": "section-header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo",
      "info": "Upload your transparent PNG logo. Recommended width: 300-400px."
    },
    {
      "type": "range",
      "id": "logo_height",
      "label": "Logo height",
      "min": 30,
      "max": 80,
      "step": 2,
      "default": 52,
      "unit": "px",
      "info": "Controls how tall the logo appears in the nav bar"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu",
      "info": "Select your nav menu from Online Store → Navigation"
    },
    {
      "type": "textarea",
      "id": "announcement_text",
      "label": "Announcement bar text",
      "default": "✨ Posh Ambassador · Free Shipping $75+ · Authenticated Vintage Coach · New Drops Weekly ✨",
      "info": "Leave blank to hide the announcement bar"
    }
  ],
  "presets": [
    {
      "name": "Header"
    }
  ]
}
{% endschema %}
