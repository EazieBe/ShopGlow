{%- if section.settings.announcement_text != blank -%}
<div class="gic-announcement" id="gic-ann">
  {{ section.settings.announcement_text }}
  <button class="announcement-close" onclick="this.closest('.gic-announcement').style.cssText='height:0;padding:0;overflow:hidden;opacity:0;transition:all .3s'">✕</button>
</div>
{%- endif -%}

<nav class="gic-nav" id="gic-nav">
  <div class="nav-inner">
    <a href="{{ routes.root_url }}" class="nav-logo">
      {%- if section.settings.logo != blank -%}
        <img src="{{ section.settings.logo | image_url: width: 400 }}"
             alt="{{ shop.name }}"
             width="{{ section.settings.logo.width }}"
             height="{{ section.settings.logo.height }}"
             loading="eager">
      {%- else -%}
        <span style="font-family:'Cormorant Garamond',serif;font-size:1.4rem;font-weight:600;background:linear-gradient(135deg,#C9A84C,#F0D080);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">{{ shop.name }}</span>
      {%- endif -%}
    </a>

    <ul class="nav-links">
      {%- for link in section.settings.menu.links -%}
        <li>
          <a href="{{ link.url }}" class="nav-link{% if link.active %} active{% endif %}{% if link.title contains 'Sale' %} sale{% endif %}">
            {{ link.title }}
          </a>
        </li>
      {%- endfor -%}
    </ul>

    <div class="nav-actions">
      <button class="nav-icon-btn" data-action="search" aria-label="Search">
        <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
      </button>
      <a href="{{ routes.cart_url }}" class="nav-icon-btn" aria-label="Cart">
        <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
        {%- if cart.item_count > 0 -%}
          <span class="cart-count">{{ cart.item_count }}</span>
        {%- else -%}
          <span class="cart-count" style="display:none">0</span>
        {%- endif -%}
      </a>
      <a href="{{ routes.collections_url }}" class="nav-shop-btn">Shop Now ✨</a>
      <button class="mobile-menu-btn" aria-label="Menu" aria-expanded="false">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
    </div>
  </div>

  <div class="mobile-nav" id="mobile-nav">
    {%- for link in section.settings.menu.links -%}
      <a href="{{ link.url }}" class="mobile-nav-link">{{ link.title }}</a>
    {%- endfor -%}
    <div style="height:1px;background:rgba(201,168,76,.12);margin:8px 0;"></div>
    <a href="{{ routes.cart_url }}" class="mobile-nav-link">🛍 Cart ({{ cart.item_count }})</a>
  </div>
</nav>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo",
      "info": "Upload your transparent PNG logo. Recommended: 400px wide."
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width",
      "min": 80,
      "max": 300,
      "step": 10,
      "default": 160,
      "unit": "px"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu"
    },
    {
      "type": "textarea",
      "id": "announcement_text",
      "label": "Announcement bar text",
      "default": "✨ Posh Ambassador · Free Shipping $75+ · Authenticated Vintage Coach · New Drops Weekly ✨"
    }
  ],
  "presets": [{ "name": "Header" }]
}
{% endschema %}
