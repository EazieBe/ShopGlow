<section class="gic-instagram">
  <div class="sec-hdr">
    <div class="sec-eyebrow">Follow Along</div>
    <h2 class="sec-title">{{ section.settings.title }} <em>{{ section.settings.title_em }}</em></h2>
    <p class="sec-sub">{{ section.settings.subtitle }}</p>
  </div>

  <div class="insta-grid">
    {%- for block in section.blocks -%}
      <a href="{{ block.settings.link | default: section.settings.instagram_url }}" class="insta-tile" target="_blank" {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          <img src="{{ block.settings.image | image_url: width: 400 }}" alt="Instagram post" style="width:100%;height:100%;object-fit:cover;position:absolute;inset:0;">
        {%- endif -%}
        <div class="insta-tile-overlay">
          <div class="insta-overlay-icon">📸</div>
        </div>
      </a>
    {%- else -%}
      {%- for i in (1..6) -%}
        <div class="insta-tile"></div>
      {%- endfor -%}
    {%- endfor -%}
  </div>

  <a href="{{ section.settings.instagram_url }}" target="_blank" class="insta-follow-btn">
    📸 &nbsp; Follow @glowingincoach
  </a>
</section>

{% schema %}
{
  "name": "Instagram Feed",
  "max_blocks": 6,
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "Follow the" },
    { "type": "text", "id": "title_em", "label": "Title Emphasis", "default": "Glow" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Shop our looks and get first access to new drops on Instagram" },
    { "type": "url", "id": "instagram_url", "label": "Instagram URL" }
  ],
  "blocks": [
    {
      "type": "post",
      "name": "Instagram Post",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Post Image" },
        { "type": "url", "id": "link", "label": "Post Link" }
      ]
    }
  ],
  "presets": [{ "name": "Instagram Feed" }]
}
{% endschema %}
