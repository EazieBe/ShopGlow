<section class="gic-poshmark-cta">
  <div class="posh-cta-bg"></div>
  <div class="posh-cta-inner">

    <div class="posh-cta-content">
      <div class="posh-eyebrow">✦ {{ section.settings.eyebrow }}</div>
      <h2 class="posh-title">{{ section.settings.title }} <em>{{ section.settings.title_em }}</em></h2>
      <p class="posh-sub">{{ section.settings.subtext }}</p>

      <div class="posh-stats">
        <div class="posh-stat"><span class="posh-stat-n">{{ section.settings.stat_listings }}</span><span class="posh-stat-l">Listings</span></div>
        <div class="posh-stat-div"></div>
        <div class="posh-stat"><span class="posh-stat-n">{{ section.settings.stat_followers }}</span><span class="posh-stat-l">Followers</span></div>
        <div class="posh-stat-div"></div>
        <div class="posh-stat"><span class="posh-stat-n">{{ section.settings.stat_rating }}</span><span class="posh-stat-l">Rating</span></div>
        <div class="posh-stat-div"></div>
        <div class="posh-stat"><span class="posh-stat-n">{{ section.settings.stat_shares }}</span><span class="posh-stat-l">Shares</span></div>
      </div>

      <div class="posh-cta-btns">
        <a href="{{ section.settings.poshmark_url | default: 'https://poshmark.com/closet/glowingincoach' }}"
           class="btn-gold posh-btn" target="_blank" rel="noopener">
          {{ section.settings.btn_text }}
        </a>
        <a href="{{ section.settings.btn2_url | default: routes.collections_url }}" class="posh-btn-ghost">
          {{ section.settings.btn2_text }}
        </a>
      </div>
    </div>

    <div class="posh-live-feed">
      <div class="posh-feed-header">
        <span class="posh-feed-label">✦ Live from my closet</span>
        <span class="posh-feed-dot"></span>
        <span class="posh-feed-live">Updated daily</span>
      </div>
      <div class="posh-feed-grid" id="posh-feed-grid">
        <div class="posh-skeleton"></div>
        <div class="posh-skeleton"></div>
        <div class="posh-skeleton"></div>
        <div class="posh-skeleton"></div>
        <div class="posh-skeleton"></div>
        <div class="posh-skeleton"></div>
      </div>
      <a href="{{ section.settings.poshmark_url | default: 'https://poshmark.com/closet/glowingincoach' }}"
         class="posh-see-all" target="_blank" rel="noopener">See all listings →</a>
    </div>

  </div>
</section>

<script>
(function() {
  var USERNAME  = 'glowingincoach';
  var CLOSET    = 'https://poshmark.com/closet/' + USERNAME;
  var grid      = document.getElementById('posh-feed-grid');
  if (!grid) return;

  // Real photos from your actual Poshmark CDN — always show these as base
  var FALLBACK = [
    { id:'69508cbaa0dc2b17fe72a44c', title:'Bone & Black Vintage Coach Slim Zip',          price:180, img:'https://di2ponv0v5otw.cloudfront.net/posts/2025/12/27/69508cbaa0dc2b17fe72a44c/s_69508d237ac6295bbc669406.jpg' },
    { id:'69606e901986c28e4a3da9d0', title:'Red & Tan Dooney & Bourke Crossbody',          price:75,  img:'https://di2ponv0v5otw.cloudfront.net/posts/2026/01/08/69606e901986c28e4a3da9d0/s_69606f69c71ba1e35c8023bf.jpg' },
    { id:'69686da2243dae047ef690da', title:'Patricia Nash London Saddle Bag',               price:70,  img:'https://di2ponv0v5otw.cloudfront.net/posts/2026/01/14/69686da2243dae047ef690da/s_69686de7310f1cfb68c34281.jpg' },
    { id:'695c91fdd8024c91fe06001e', title:'Michael Kors White & Tan Bucket Bag',          price:75,  img:'https://di2ponv0v5otw.cloudfront.net/posts/2026/01/05/695c91fdd8024c91fe06001e/s_695c92748500126b86bca764.jpg' },
    { id:'69507c7921bd42426d0ebd28', title:'Vintage Coach Anderson 9976 Navy Blue',        price:180, img:'https://di2ponv0v5otw.cloudfront.net/posts/2025/12/27/69507c7921bd42426d0ebd28/s_69507ce2d8024cef49197a4d.jpg' },
    { id:'698d0a434a072b4e13b877d4', title:'Vintage Coach 9997 Black Leather Shoulder',   price:232, img:'https://di2ponv0v5otw.cloudfront.net/posts/2026/02/11/698d0a434a072b4e13b877d4/s_698d0ac42981afd25f8675aa.jpg' }
  ];

  function fmt(n) {
    n = parseInt(n) || 0;
    return n >= 1000 ? (n/1000).toFixed(1).replace('.0','') + 'K' : String(n);
  }

  function renderCards(items) {
    grid.innerHTML = items.slice(0,6).map(function(item) {
      var img   = item.cover_shot ? (item.cover_shot.url_small || item.cover_shot.url || '') : (item.img || '');
      var price = item.price_amount ? parseFloat(item.price_amount.val||0).toFixed(0) : String(item.price||'');
      var title = item.title || item.name || '';
      var link  = item.id ? 'https://poshmark.com/listing/' + item.id : CLOSET;
      return '<a href="'+link+'" target="_blank" rel="noopener" class="posh-live-card">' +
        '<div class="plc-img plc-img-real">' +
          '<img src="'+img+'" alt="'+title.replace(/"/g,'')+'" loading="lazy" ' +
          'onerror="this.parentElement.innerHTML=\'👜\'">' +
        '</div>' +
        '<div class="plc-info">' +
          '<div class="plc-name">'+title.substring(0,38)+(title.length>38?'…':'')+'</div>' +
          '<div class="plc-price">$'+price+'</div>' +
        '</div>' +
      '</a>';
    }).join('');
  }

  // Stats managed via Customize settings

  // Show real photos immediately — no waiting
  renderCards(FALLBACK);

  // Then try to upgrade to live data in the background
  // Use allorigins /get endpoint (returns JSON wrapper with CORS headers)
  var FEED_URL = 'https://poshmark.com/vm/closet/feed?username='+USERNAME+'&max_id=0&summarize=true';

  function alloriginsGet(url) {
    return fetch('https://api.allorigins.win/get?url=' + encodeURIComponent(url))
      .then(function(r) { return r.json(); })
      .then(function(d) { return JSON.parse(d.contents); });
  }

  // Stats are set in Customize — no fetch needed

  // Try live listings
  alloriginsGet(FEED_URL)
    .then(function(data) {
      var listings = data.data || data || [];
      var available = listings.filter(function(i) {
        return (i.inventory && i.inventory.status === 'available') || i.status === 'available';
      });
      if (available.length > 0) renderCards(available);
      // else keep the fallback already showing
    })
    .catch(function() {}); // Silent fail — fallback photos stay

})();
</script>

{% schema %}
{
  "name": "Poshmark CTA",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Shop My Closet" },
    { "type": "text", "id": "stat_listings", "label": "Listings count", "default": "246+" },
    { "type": "text", "id": "stat_followers", "label": "Followers count", "default": "16.5K" },
    { "type": "text", "id": "stat_rating", "label": "Rating", "default": "5★" },
    { "type": "text", "id": "stat_shares", "label": "Shares count", "default": "17.8K" },
    { "type": "text", "id": "title", "label": "Title", "default": "Shop My" },
    { "type": "text", "id": "title_em", "label": "Title emphasis", "default": "Poshmark Closet." },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Browse authenticated vintage Coach bags, designer handbags & fashion finds. New listings added every week." },
    { "type": "url", "id": "poshmark_url", "label": "Poshmark closet URL" },
    { "type": "text", "id": "btn_text", "label": "Button 1 text", "default": "Visit My Poshmark Closet ↗" },
    { "type": "url", "id": "btn2_url", "label": "Button 2 URL" },
    { "type": "text", "id": "btn2_text", "label": "Button 2 text", "default": "Shop This Site" }
  ],
  "presets": [{ "name": "Poshmark CTA" }]
}
{% endschema %}
