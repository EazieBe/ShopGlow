<section class="gic-poshmark-cta">
  <div class="posh-cta-inner">

    <div class="posh-cta-bg"></div>

    <div class="posh-cta-content">
      <div class="posh-eyebrow">✦ {{ section.settings.eyebrow }}</div>
      <h2 class="posh-title">{{ section.settings.title }} <em>{{ section.settings.title_em }}</em></h2>
      <p class="posh-sub">{{ section.settings.subtext }}</p>

      <div class="posh-stats">
        <div class="posh-stat"><span class="posh-stat-n">246+</span><span class="posh-stat-l">Active Listings</span></div>
        <div class="posh-stat-div"></div>
        <div class="posh-stat"><span class="posh-stat-n">16.5K</span><span class="posh-stat-l">Followers</span></div>
        <div class="posh-stat-div"></div>
        <div class="posh-stat"><span class="posh-stat-n">5★</span><span class="posh-stat-l">Seller Rating</span></div>
        <div class="posh-stat-div"></div>
        <div class="posh-stat"><span class="posh-stat-n">17.8K</span><span class="posh-stat-l">Items Shared</span></div>
      </div>

      <div class="posh-cta-btns">
        <a href="{{ section.settings.poshmark_url | default: 'https://poshmark.com/closet/glowingincoach' }}"
           class="btn-gold posh-btn" target="_blank" rel="noopener">
          {{ section.settings.btn_text }}
        </a>
        <a href="{{ section.settings.btn2_url | default: routes.collections_url }}" class="btn-ghost posh-btn-ghost">
          {{ section.settings.btn2_text }}
        </a>
      </div>
    </div>

    <!-- Decorative listing cards -->
    <div class="posh-cards">
      <div class="posh-card pc1">
        <div class="posh-card-img">👜</div>
        <div class="posh-card-info">
          <div class="posh-card-brand">Coach</div>
          <div class="posh-card-name">Vintage Slim Zip</div>
          <div class="posh-card-price">$180</div>
        </div>
        <div class="posh-card-badge">Vintage</div>
      </div>
      <div class="posh-card pc2">
        <div class="posh-card-img">👝</div>
        <div class="posh-card-info">
          <div class="posh-card-brand">Dooney & Bourke</div>
          <div class="posh-card-name">Signature Crossbody</div>
          <div class="posh-card-price">$75</div>
        </div>
        <div class="posh-card-badge">Sold</div>
      </div>
      <div class="posh-card pc3">
        <div class="posh-card-img">💼</div>
        <div class="posh-card-info">
          <div class="posh-card-brand">Coach</div>
          <div class="posh-card-name">Leather Satchel</div>
          <div class="posh-card-price">$220</div>
        </div>
        <div class="posh-card-badge">New</div>
      </div>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Poshmark CTA",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Shop My Closet" },
    { "type": "text", "id": "title", "label": "Title", "default": "Find your next" },
    { "type": "text", "id": "title_em", "label": "Title emphasis", "default": "favourite bag." },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Browse 246+ authenticated vintage Coach bags, designer handbags & fashion finds on my Poshmark closet. New listings added every week." },
    { "type": "text", "id": "btn_text", "label": "Button text", "default": "Visit My Poshmark Closet ↗" },
    { "type": "url", "id": "poshmark_url", "label": "Poshmark URL" },
    { "type": "text", "id": "btn2_text", "label": "Button 2 text", "default": "Shop This Site" },
    { "type": "url", "id": "btn2_url", "label": "Button 2 URL" }
  ],
  "presets": [{ "name": "Poshmark CTA" }]
}
{% endschema %}
