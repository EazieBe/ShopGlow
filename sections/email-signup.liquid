<section class="gic-why-glo">
  <div class="why-inner">

    <div class="why-left">
      <div class="sec-eyebrow">Why Shop With Glo</div>
      <h2 class="sec-title">Trusted by <em>thousands</em> of happy shoppers.</h2>
      <p class="why-sub">Every bag is personally authenticated, carefully described, and shipped with love. No surprises — just beautiful finds.</p>

      <div class="why-grid">
        {%- for block in section.blocks -%}
          <div class="why-card" {{ block.shopify_attributes }}>
            <div class="why-icon">{{ block.settings.icon }}</div>
            <div class="why-title">{{ block.settings.title }}</div>
            <div class="why-text">{{ block.settings.text }}</div>
          </div>
        {%- endfor -%}
      </div>
    </div>

    <div class="why-right">
      <div class="why-review-stack">
        <div class="why-big-stat">
          <span class="why-big-num">5.0</span>
          <div class="why-stars">⭐⭐⭐⭐⭐</div>
          <div class="why-stat-label">Average seller rating</div>
        </div>
        <div class="why-review">
          <div class="why-rev-stars">⭐⭐⭐⭐⭐</div>
          <p class="why-rev-text">"Bag arrived exactly as described — absolutely beautiful. Glo packages everything so carefully. Will definitely buy again!"</p>
          <div class="why-rev-by">— Verified Poshmark Buyer</div>
        </div>
        <div class="why-review">
          <div class="why-rev-stars">⭐⭐⭐⭐⭐</div>
          <p class="why-rev-text">"Fast shipping, gorgeous vintage Coach bag in perfect condition. Glo knows her stuff — completely trustworthy seller."</p>
          <div class="why-rev-by">— Verified Poshmark Buyer</div>
        </div>
        <div class="why-review">
          <div class="why-rev-stars">⭐⭐⭐⭐⭐</div>
          <p class="why-rev-text">"Third purchase and every single one has exceeded expectations. My go-to for designer bags. Love love love!"</p>
          <div class="why-rev-by">— Verified Poshmark Buyer</div>
        </div>
      </div>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Why Shop With Glo",
  "blocks": [
    {
      "type": "reason",
      "name": "Reason",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon (emoji)", "default": "✅" },
        { "type": "text", "id": "title", "label": "Title", "default": "Authenticated" },
        { "type": "textarea", "id": "text", "label": "Description", "default": "Every vintage piece is personally verified before listing." }
      ]
    }
  ],
  "presets": [{
    "name": "Why Shop With Glo",
    "blocks": [
      { "type": "reason", "settings": { "icon": "✅", "title": "100% Authenticated", "text": "Every vintage Coach bag personally verified before listing." } },
      { "type": "reason", "settings": { "icon": "🚚", "title": "Fast Shipping", "text": "Ships within 1-2 days, beautifully packaged every time." } },
      { "type": "reason", "settings": { "icon": "💛", "title": "Handpicked by Glo", "text": "Only pieces I personally love make it into the closet." } },
      { "type": "reason", "settings": { "icon": "↩️", "title": "Easy Returns", "text": "14-day return policy, no questions asked." } }
    ]
  }]
}
{% endschema %}
