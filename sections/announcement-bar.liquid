{%- if section.settings.text != blank -%}
<div class="gic-announcement" id="gic-ann">
  <span>{{ section.settings.text }}</span>
  <button class="announcement-close" onclick="document.getElementById('gic-ann').style.cssText='height:0;padding:0;overflow:hidden;opacity:0;transition:all .3s';sessionStorage.setItem('gic-ann','1');" aria-label="Close">✕</button>
</div>
<script>if(sessionStorage.getItem('gic-ann'))document.getElementById('gic-ann').style.display='none';</script>
{%- endif -%}

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Announcement Text",
      "default": "✨ Posh Ambassador · Free Shipping $75+ · New Drops Weekly · Authenticated Vintage Coach ✨"
    }
  ],
  "presets": [{ "name": "Announcement Bar" }]
}
{% endschema %}
